# Akarshan Backend Environment Variables Example
# Copy this file to .env and fill in the values from your Supabase Dashboard

PORT=5000
NODE_ENV=development

# 1. Database Connection (Direct Transaction connection string)
# Go to Supabase Dashboard -> Project Settings -> Database -> Connection string (URI)
# Example: postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.[project-id]:[your-password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# 2. Supabase API Credentials
# Go to Project Settings -> API
SUPABASE_URL="https://[project-id].supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# 3. Allowed Client URL for CORS Security
# In production, set this to your Vercel deployment URL
CLIENT_URL="http://localhost:3000"
